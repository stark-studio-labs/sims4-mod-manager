{
  "name": "sims4-mod-manager",
  "productName": "Stark Labs Mod Manager",
  "version": "1.1.0",
  "description": "One-click installer for Stark Labs Sims 4 mods. Auto-detects your game, installs mods, enables scripts, checks for updates.",
  "main": "src/main/main.js",
  "author": {
    "name": "Stark Labs",
    "email": "studio@starklabs.dev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stark-studio-labs/sims4-mod-manager.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "dev.starklabs.sims4-mod-manager",
    "productName": "Stark Labs Mod Manager",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "background": "build/background.png",
      "iconSize": 128,
      "contents": [
        { "x": 190, "y": 200 },
        { "x": 470, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "stark-studio-labs",
      "repo": "sims4-mod-manager"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  }
}
